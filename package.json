{
  "name": "lol-agent",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -- tsx src/index.ts",
    "start": "dotenvx run -- tsx src/index.ts",
    "watch": "dotenvx run -- tsx src/watch.ts",
    "send-update": "dotenvx run -- tsx scripts/send-update.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart idv-lol-agent --update-env",
    "pm2:update": "git pull --ff-only && npm install --no-audit --no-fund && pm2 restart idv-lol-agent --update-env"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "league-connect": "^5.1.2",
    "pg": "^8.20.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
